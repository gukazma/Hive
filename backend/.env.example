# 复制为 .env 并按需修改
PORT=8080
DATABASE_URL=host=postgres user=hive password=hive dbname=hive port=5432 sslmode=disable TimeZone=Asia/Shanghai
REDIS_ADDR=redis:6379
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173

# 首次启动若库中无用户，按此创建超级管理员（登录后请尽快改密）
ADMIN_EMAIL=admin@hive.local
ADMIN_PASSWORD=admin
